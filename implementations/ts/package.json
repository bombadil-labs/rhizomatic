{
  "name": "@bombadil/rhizomatic",
  "version": "0.4.0",
  "type": "module",
  "description": "Rhizomatic (TypeScript) — a portable format for arbitrarily-relational data: signed, content-addressed deltas; union merge (grow-only CRDT); truth resolved per-reader. One of two parallel witnesses to the spec.",
  "license": "MIT OR Apache-2.0",
  "author": "Mykola Bilokonsky",
  "homepage": "https://github.com/bombadil-labs/rhizomatic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bombadil-labs/rhizomatic.git",
    "directory": "implementations/ts"
  },
  "bugs": {
    "url": "https://github.com/bombadil-labs/rhizomatic/issues"
  },
  "keywords": [
    "crdt",
    "content-addressed",
    "provenance",
    "canonical-cbor",
    "delta",
    "federation",
    "rhizomatic",
    "signed-data"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "preversion": "npm run check",
    "version": "npm run build",
    "release:patch": "tsx tools/release.ts patch",
    "release:minor": "tsx tools/release.ts minor",
    "release:major": "tsx tools/release.ts major",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "gen-vectors": "tsx tools/gen-vectors.ts",
    "demo": "tsx demo/demo.ts",
    "playground:build": "esbuild demo/playground/playground.ts --bundle --format=iife --outfile=demo/playground/bundle.js",
    "docs:build": "esbuild demo/tour/tour.ts --bundle --format=iife --outfile=../../docs/tour.bundle.js && esbuild demo/playground/playground.ts --bundle --format=iife --outfile=../../docs/playground.bundle.js"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^3.22.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.0"
  }
}
