# Normalize all text to LF in the repo, regardless of platform.
# Byte-exact conformance vectors and cross-implementation parity depend on
# stable line endings; never let Windows CRLF leak into committed files.
* text=auto eol=lf

# Vector and source files are always text.
*.json   text eol=lf
*.md     text eol=lf
*.ts     text eol=lf
*.rs     text eol=lf
*.toml   text eol=lf

# Binary artifacts (none yet, but be explicit when they arrive).
*.wasm   binary
*.png    binary
