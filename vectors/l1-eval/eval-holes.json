  "schemas": [
    {
      "name": "ViewAsOf",
      "alg": 1,
      "body": {
        "op": "group",
        "key": "byTargetContext",
        "in": {
          "op": "mask",
          "policy": "drop",
          "in": {
            "op": "select",
            "pred": {
              "match": {
                "field": "timestamp",
                "cmp": "lte",
                "const": {
                  "hole": "asOf"
                }
              }
            },
            "in": "input"
          }
        }
      }
    },
    {
      "name": "RatedAtLeast",
      "alg": 1,
      "body": {
        "op": "group",
        "key": "byTargetContext",
        "in": {
          "op": "mask",
          "policy": "drop",
          "in": {
            "op": "select",
            "pred": {
              "or": [
                {
                  "not": {
                    "hasPointer": {
                      "context": {
                        "exact": "rating"
                      }
                    }
                  }
                },
                {
                  "hasPointer": {
                    "targetValue": {
                      "vcmp": {
                        "cmp": "gte",
                        "value": {
                          "hole": "min"
                        }
                      }
                    }
                  }
                }
              ]
            },
            "in": "input"
          }
        }
      }
    },
    {
      "name": "LinkedTo",
      "alg": 1,
      "body": {
        "op": "group",
        "key": "byTargetContext",
        "in": {
          "op": "mask",
          "policy": "drop",
          "in": {
            "op": "select",
            "pred": {
              "hasPointer": {
                "targetEntity": {
                  "hole": "who"
                }
              }
            },
            "in": "input"
          }
        }
      }
    }
